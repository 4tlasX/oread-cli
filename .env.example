OLLAMA_URL=http://localhost:11434
OLLAMA_CHAT_MODEL=llama3.2
OLLAMA_EXTRACTION_MODEL=phi4-mini
CHAT_TEMPLATES_DIR=
OLLAMA_MAX_LOADED_MODELS=2

# External AI provider default models (use the raw ID, prefix is added automatically)
NOMI_MODEL=
KINDROID_MODEL=

# Cloud provider API keys (alternative to /key set <provider> <key>)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
NOMI_API_KEY=
KINDROID_API_KEY=

#Cloudflare Integration
CF_ACCOUNT_ID= # Cloudflare account ID
CF_API_TOKEN=  # Cloudflare API token (Workers AI: Run permission)